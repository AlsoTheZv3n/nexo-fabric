# ============================================
# NEXO Fabric - Environment Variables
# Copy this to .env and fill in real values
# ============================================

# --- Database ---
DB_URL=jdbc:postgresql://localhost:5434/nexo_ontology
DB_USERNAME=nexo
DB_PASSWORD=CHANGE_ME

POSTGRES_DB=nexo_ontology
POSTGRES_USER=nexo
POSTGRES_PASSWORD=CHANGE_ME

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Server ---
SERVER_PORT=8081

# --- Auth ---
AUTH_ENFORCED=true

# --- JWT ---
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_256_BIT_STRING
JWT_EXPIRATION=86400000

# --- n8n ---
N8N_WEBHOOK_SECRET=CHANGE_ME
N8N_CALLBACK_URL=http://localhost:8081
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME

# --- CDC (optional) ---
CDC_ENABLED=false

# --- LLM Provider ---
# Options: none | anthropic | openai | ollama
NEXO_LLM_PROVIDER=none

# Anthropic (if NEXO_LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20251001

# OpenAI (if NEXO_LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Ollama (if NEXO_LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
